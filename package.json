{
  "name": "bg-calendar",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.vue",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "core-js": "^3.8.3",
    "date-fns": "^4.1.0",
    "firebase": "^11.1.0",
    "vue": "^3.5.30",
    "vue-textarea-autosize": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^8.0.3",
    "pinia": "^3.0.4",
    "prettier": "^3.8.1",
    "sass": "^1.77.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.19",
    "vue-tsc": "^3.0.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "vue/setup-compiler-macros": true
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "prettier"
    ],
    "parser": "vue-eslint-parser",
    "parserOptions": {
      "parser": "@typescript-eslint/parser"
    },
    "rules": {
      "vue/multi-word-component-names": "off",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ]
    },
    "ignorePatterns": [
      "dist",
      "node_modules"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
